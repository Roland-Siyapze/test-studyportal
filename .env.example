# ─────────────────────────────────────────────────────────────────
# KEYCLOAK CONFIGURATION
# ─────────────────────────────────────────────────────────────────

# Keycloak server URL (e.g., https://keycloak.example.com or http://localhost:8080)
VITE_KEYCLOAK_URL=http://localhost:8080

# Keycloak realm name (created in your Keycloak admin console)
VITE_KEYCLOAK_REALM=boaz-study

# Keycloak client ID (configured in your Keycloak realm > Clients)
VITE_KEYCLOAK_CLIENT_ID=studyportal-app

# ─────────────────────────────────────────────────────────────────
# API CONFIGURATION
# ─────────────────────────────────────────────────────────────────

# Backend API base URL
VITE_API_BASE_URL=http://localhost:8081/api

# ─────────────────────────────────────────────────────────────────
# AUTHENTICATION MODE
# ─────────────────────────────────────────────────────────────────

# Set to 'true' to use mock authentication (no Keycloak server required)
# Set to 'false' to use real Keycloak authentication
VITE_USE_MOCK_AUTH=false
